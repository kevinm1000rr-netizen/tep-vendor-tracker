# Copy to `.env` in this folder. Anthropic can also be set in the app Settings screen.
# Keys in Settings (`.tep-config.json`) are overridden when the same variable is set here.
# Optional: absolute path or path relative to project root for the JSON config file (default: .tep-config.json).
# TEP_CONFIG_PATH=

# When set, the API uses PostgreSQL (Railway, Neon, etc.) instead of vendor_tracker.db.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Frontend → backend (Vite build-time). Leave unset on Railway: the SPA uses same-origin `/api`.
# For local dev with API on 3099: VITE_API_BASE_URL=http://127.0.0.1:3099/api
# VITE_API_BASE_URL=

# Railway / production: PORT is set automatically. Local default is 3000 in server code.
# PORT=

# SQLite only (when DATABASE_URL is unset). On Railway, add a volume mounted at /data and set:
# SQLITE_DB_PATH=/data/vendor_tracker.db
# SQLITE_DB_PATH=

ANTHROPIC_API_KEY=your_new_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5
# Daily 06:00 research cron when true; false = manual POST /api/agent/run-now only (omit defaults to true in app).
AGENT_AUTO_RUN=true

# Live loop: enrich + discovery + auto-registry + drafts every N minutes (5–180). Or LIVE_AGENT_MODE=true for default 30.
# LIVE_AGENT_INTERVAL_MINUTES=30
# LIVE_AGENT_MODE=true

# Optional — Research & Outreach agent (Agent Review)
SERPAPI_API_KEY=your_serpapi_key
GOOGLE_PLACES_API_KEY=your_google_places_key

# Outbound email (Nodemailer) — GoDaddy / secureserver (defaults match if omitted)
# All outreach sends From: kevin@triexpressplumbing.com (fixed in app). Auth uses SMTP_USER / SMTP_PASS.
# Test Email in Settings delivers to SMTP_USER to verify the relay.
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USER=kevin@triexpressplumbing.com
SMTP_PASS=
SMTP_FROM_NAME=Kevin | Tri Express Plumbing

# Permit Intelligence agent — only keep leads with lead_score >= this threshold (1–10, default 7).
# Anything below is rejected on ingest, and existing rows below this threshold are purged at startup.
# PERMIT_LEAD_MIN_SCORE=7

# Optional — Accela Construct API (developer.accela.com) for Chula Vista + National City when your app is provisioned for agencies CHULAVISTA and PRCITY.
# ACCELA_CLIENT_ID=
# ACCELA_CLIENT_SECRET=
# ACCELA_ENVIRONMENT=PRODUCTION
# ACCELA_SCOPE=

# Optional — AI plumbing estimate widget (POST /api/estimate/*)
# ESTIMATE_ANTHROPIC_MODEL=claude-sonnet-4-5
# SMS for new estimate leads (E.164). Defaults to +16198436692 if unset.
# ESTIMATE_SMS_TO=+16198436692
# Owner notification links in estimate SMS (default http://localhost:5173/leads)
# CRM_LEADS_URL=https://YOUR-APP.up.railway.app/permits

# Twilio (SMS alerts, estimate widget)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx
# Prefer Messaging Service SID when using A2P 10DLC (starts with MG)
# TWILIO_MESSAGING_SERVICE_SID=
# ALERT_PHONE=+1xxxxxxxxxx
